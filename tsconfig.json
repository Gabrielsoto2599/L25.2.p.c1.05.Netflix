{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    /* Language and Environment */
    "target": "ES2022", /* Versión moderna para Soto System */
    "lib": ["DOM", "ESNext"], /* Necesario para trabajar con el navegador */
    
    /* Modules */
    "module": "ESNext", /* Para que los import/export funcionen bien */
    "moduleResolution": "node",
    "rootDir": "./", /* Tu raíz de proyecto */

    /* Emit */
    "outDir": "./", /* Genera los .js en la misma carpeta */
    "removeComments": true,
    "noEmitOnError": true,

    /* JavaScript Support */
    "allowJs": true, /* Por si mezclas archivos .js viejos */
    "checkJs": false, /* No revisa errores en los .js para no estresarte */

    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true, /* El sello de calidad de un Senior */
    "skipLibCheck": true /* Omite revisar librerías externas */
  }
}
