{
  "compilerOptions": {
    /* 1. Configuración del Entorno (Soto System 2026) */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx", /* Mantenemos esto por si escalamos a React en el futuro */

    /* 2. Organización de Archivos */
    "rootDir": "./",
    "outDir": "./",

    /* 3. Reglas de Oro (Stricter Typechecking) */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true,

    /* 4. Interoperabilidad y Limpieza */
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "removeComments": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}

